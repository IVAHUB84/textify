BOT_TOKEN=<your_bot_token>

LLM_PROVIDER=cloudflare
CF_ACCOUNT_ID=<your_cloudflare_account_id>
CF_API_TOKEN=<your_cloudflare_api_token>
CF_MODEL=@cf/meta/llama-3.1-8b-instruct
GROQ_API_KEY=<your_groq_api_key>

ASR_PROVIDER=cloudflare
CF_WHISPER_MODEL=@cf/openai/whisper-large-v3-turbo

ADMIN_USER_ID=<telegram_user_id>
STATS_DB_PATH=/app/data/stats.db

# Дневной лимит обращений к Cloudflare Workers AI (число вызовов за UTC-сутки).
# При достижении лимита ASR и LLM деградируют на локальные бесплатные движки.
CF_DAILY_BUDGET=300

# В группах ASR по умолчанию идёт локальным faster-whisper (не тратит CF-бюджет лички).
# false → группы используют общий путь ASR_PROVIDER + дневной бюджет CF.
GROUP_ASR_LOCAL=true

# LOG_LEVEL=INFO
